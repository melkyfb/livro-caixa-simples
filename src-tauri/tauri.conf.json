{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Livro-Caixa-Simples",
  "version": "0.1.2",
  "identifier": "com.github.melkyfb.livro-caixa-simples",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Livro Caixa Simples",
        "width": 1200,
        "height": 900,
        "resizable": false,
        "fullscreen": false,
        "maximized": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://raw.githubusercontent.com/melkyfb/livro-caixa-simples/main/update.json"
      ],
      "dialog": true,
      "pubkey": "RWRgl71QnRH1e+7dTWOnjckG4C4l8g+9QVztvpWQ5i6HEBst+WBZVsEO"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
