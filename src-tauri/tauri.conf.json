{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Livro Caixa Simples",
  "version": "0.1.4",
  "identifier": "com.github.melkyfb.livro-caixa-simples",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Livro Caixa Simples",
        "width": 1200,
        "height": 900,
        "resizable": false,
        "fullscreen": false,
        "maximized": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/melkyfb/livro-caixa-simples/releases/latest/download/latest.json"
      ],
      "dialog": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IENCN0NCOUEwM0EyOUE1QgpSV1JibXFJRG1zdTNEQkJicTZ5YnhqaEhxeHZ1QWNhNzIzdk5kU1lSTFRFTUtUR0dLUWF3NzdyZwo="
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    },
    "createUpdaterArtifacts": true
  }
}
